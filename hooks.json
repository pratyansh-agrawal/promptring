{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "\"$HOME/.copilot/promptring/bin/promptring.py\" done >/dev/null 2>&1 || true",
        "powershell": "python \"$env:USERPROFILE\\.copilot\\promptring\\bin\\promptring.py\" done"
      }
    ],
    "notification": [
      {
        "type": "command",
        "matcher": "permission_prompt",
        "bash": "\"$HOME/.copilot/promptring/bin/promptring.py\" input 'Permission needed' >/dev/null 2>&1 || true",
        "powershell": "python \"$env:USERPROFILE\\.copilot\\promptring\\bin\\promptring.py\" input 'Permission needed'"
      },
      {
        "type": "command",
        "matcher": "elicitation_dialog",
        "bash": "\"$HOME/.copilot/promptring/bin/promptring.py\" input 'Input requested' >/dev/null 2>&1 || true",
        "powershell": "python \"$env:USERPROFILE\\.copilot\\promptring\\bin\\promptring.py\" input 'Input requested'"
      }
    ]
  }
}
